# Disable MultiViews to prevent Apache from resolving extensions before mod_rewrite
Options -MultiViews

# Enable rewrite engine
RewriteEngine On

# 1. Block access to sensitive files
RewriteRule ^\.env$ - [F,L]
RewriteRule ^\.gitignore$ - [F,L]
RewriteRule ^\.git/ - [F,L]
RewriteRule ^\.vscode/ - [F,L]

# 2. Redirect /filename.php to /filename (Clean URLs)
RewriteCond %{THE_REQUEST} \s/+(.*?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 3. Resolve /filename to /filename.php internally
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

# 4. Custom rule to map the React path /ai-services/ai-sales-automation to services/ai-sales-automation.php
RewriteRule ^ai-services/ai-sales-automation$ services/ai-sales-automation [L,QSA]
